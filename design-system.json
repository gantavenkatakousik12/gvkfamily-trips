          "color": "#FFFFFF",
          "borderRadius": "9999px",
          "backdropFilter": "blur(8px)",
          "padding": "13px 28px",
          "fontSize": "14px",
          "fontWeight": 500
        }
      },

      "footer": {
        "background": "#1C1C1C",
        "paddingTop": "64px",
        "paddingBottom": "32px",
        "columns": [
          {
            "id": "brand",
            "logoText": "BromoRao / BromoRise",
            "logoIconShape": "circle with mountain icon",
