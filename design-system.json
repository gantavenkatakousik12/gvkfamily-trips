        "contentAlign": "center",
        "title": "Experience the Magic of Mount Bromo Today",
        "titleColor": "#FFFFFF",
        "titleFont": "Playfair Display, 700",
        "desc": "Discover breathtaking views, volcanic landscapes, and unforgettable moments in one of Indonesia's most iconic destinations.",
