    "spacing": {
      "sectionPaddingY": "96px",
      "containerMaxWidth": "1200px",
      "containerPaddingX": "clamp(20px, 5vw, 64px)",
      "cardPadding": "20px",
      "cardGap": "16px"
    },

    "borderRadius": {
      "card": "14px",
      "image": "14px",
      "pill": "9999px",
      "button": "9999px",
      "stepActiveRow": "10px",
      "heroCard": "12px",
      "input": "9999px",
      "socialIcon": "50%"
    },

    "shadows": {
      "card": "0 2px 16px rgba(0,0,0,0.08)",
      "cardHover": "0 8px 32px rgba(0,0,0,0.14)",
      "heroFloatingCard": "0 8px 32px rgba(0,0,0,0.35)"
    },

    "navbar": {
      "height": "64px",
      "backgroundOnHero": "transparent",
      "backgroundOnScroll": "rgba(255,255,255,0.95) with backdrop-filter blur(16px)",
      "position": "fixed top:0",
      "logoColor": "#FFFFFF on hero, #111111 when scrolled",
      "links": ["Home", "Packages", "Gallery", "How it works", "Contact"],
      "cta": {
        "label": "Book now",
        "background": "#111111",
        "color": "#FFFFFF",
        "borderRadius": "9999px",
        "padding": "9px 20px",
        "fontSize": "13px",
        "fontWeight": 600
      }
    },

    "sections": {
      "hero": {
        "height": "100vh",
        "background": "full-bleed photo of Mount Bromo at sunrise/dusk",
        "overlay": "rgba(0,0,0,0.35)",
        "contentAlignment": "bottom-left",
        "paddingBottom": "80px",
        "badge": {
          "text": "East Java's Natural Wonder",
          "style": "small grey uppercase text above the title"
        },
        "title": "Unforgettable Mount Bromo Sunrise Experience",
        "titleColor": "#FFFFFF",
        "floatingPhotoCards": {
          "position": "absolute, right side of hero",
          "layout": "2 columns of stacked rounded photo cards",
          "count": 4,
          "borderRadius": "12px",
          "shadow": "0 8px 32px rgba(0,0,0,0.35)",
          "border": "none",
          "background": "real photo",
          "sizes": {
            "col1card1": "160x100px landscape",
            "col1card2": "160x190px portrait",
            "col2card1": "140x82px landscape",
            "col2card2": "140x82px landscape"
          }
        }
      },

      "moments": {
        "background": "#FFFFFF",
        "paddingY": "96px",
        "eyebrow": "Pure Adventure",
        "title": "Unforgettable Moments in the Heart of Mount Bromo",
        "titleColor": "#111111",
        "desc": "Experience breathtaking sunrises, explore volcanic landscapes, and create memories at one of Indonesia's most iconic destinations.",
        "galleryLayout": "horizontal scroll, drag/swipe",
        "galleryCards": {
          "borderRadius": "14px",
          "overflow": "hidden",
          "heights": "mixed — portrait ~280px, landscape ~210px",
          "labelOverlay": {
            "gradient": "linear-gradient(to top, rgba(0,0,0,0.6), transparent)",
            "textColor": "#FFFFFF",
            "fontSize": "13px"
          }
        },
        "navigation": {
          "prevNextButtons": "36px circle, border 1px solid #E8E4DF, bg white",
          "progressBar": "thin 2px line, grey bg, amber fill, max-width 160px"
        }
      },

      "packages": {
        "background": "#FFFFFF",
        "paddingY": "96px",
        "eyebrow": "Bromo Tours",
        "title": "Discover the Best Bromo Adventures for Every Kind of Traveler",
        "accentWords": "Bromo Adventures",
        "desc": "Carefully crafted tour packages for every traveler...",
        "layout": {
          "type": "CSS grid: 1 large left card + 2x2 right grid",
          "gap": "16px"
        },
        "featuredCard": {
          "gridArea": "spans 2 rows on left",
          "imageHeight": "100% of card",
          "titleOnImage": true,
          "titleColor": "#FFFFFF",
          "imageOverlay": "linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 50%)",
          "borderRadius": "14px"
        },
        "regularCard": {
          "imageHeight": "160px",
          "bodyPadding": "16px",
          "background": "#FFFFFF",
          "border": "none",
          "shadow": "0 2px 16px rgba(0,0,0,0.08)",
          "borderRadius": "14px",
          "priceRow": {
            "display": "flex",
            "justifyContent": "space-between",
            "alignItems": "center"
          },
          "bookNowLink": {
            "text": "Book Now →",
            "fontSize": "13px",
            "fontWeight": 600,
            "color": "#111111"
          }
        },
        "packages": [
          { "name": "Sunrise Explorer", "price": "$39", "unit": "person" },
          { "name": "Adventure Trail", "price": "$69", "unit": "person" },
          { "name": "Night & Stars Escape", "price": "$109", "unit": "person" },
          { "name": "Private Bromo Journey", "price": "$149", "unit": "person" }
        ]
      },

      "howToBook": {
        "background": "#FFFFFF",
        "paddingY": "96px",
        "mainTitle": "How to Book Your Tour",
        "subTitle": "Book Tour in 4 Easy Steps",
        "layout": "2 columns: left (tabs + steps) | right (photo)",
        "tabs": {
          "style": "small horizontal pill chips",
          "fontSize": "12px",
          "fontWeight": 500,
          "gap": "8px",
          "active": {
            "background": "#FFFFFF",
            "border": "1px solid #111111",
            "color": "#111111"
          },
          "inactive": {
            "background": "#F7F5F2",
            "border": "1px solid transparent",
            "color": "#555555"
          },
          "items": ["Exploration", "Sunrise Explorer", "Tour Guide", "Adventure", "Sunrise Viewing", "Private Bromo"]
        },
        "steps": [
          { "n": 1, "title": "Choose a Package", "desc": "Select the tour that best fits your schedule and travel style." },
          { "n": 2, "title": "Check Availability", "desc": "Pick your preferred date and group size." },
          { "n": 3, "title": "Make a Reservation", "desc": "Confirm your booking securely online in minutes." },
          { "n": 4, "title": "Enjoy the Experience", "desc": "" }
        ],
        "stepActive": {
          "background": "#FFFFFF",
          "border": "1px solid #E8E4DF",
          "borderRadius": "10px",
          "padding": "16px 20px"
        },
        "stepInactive": {
          "background": "transparent",
          "padding": "12px 20px"
        },
        "rightPhoto": {
          "aspectRatio": "4/5",
          "borderRadius": "16px",
          "overlayCard": {
            "position": "bottom: 24px, left: 24px, right: 24px",
            "background": "rgba(255,255,255,0.12)",
            "backdropFilter": "blur(12px)",
            "border": "1px solid rgba(255,255,255,0.2)",
            "borderRadius": "12px",
            "padding": "18px 20px",
            "text": "Plan your Mount Bromo adventure in minutes with our simple and secure...",
            "textColor": "#FFFFFF",
            "ctaButton": {
              "style": "circle 36px, background white, icon arrow",
              "background": "#FFFFFF",
              "color": "#111111",
              "borderRadius": "50%"
            }
          }
        }
      },

      "testimonials": {
        "background": "#FFFFFF",
        "paddingY": "80px",
        "eyebrow": "Captured Memories",
        "title": "Capture Your Mount Bromo Journey Forever",
        "desc": "Relive every sunrise, trail, and volcanic moment with professional photo and video documentation...",
        "layout": "5 cards side by side, horizontal",
        "card": {
