{
  "designSystem": {
    "brand": {
      "name": "BromoRise",
      "altName": "BromoRao"
    },

    "colors": {
      "background": {
        "page": "#FFFFFF",
        "section": "#F7F5F2",
        "card": "#FFFFFF",
        "navbar": "rgba(255,255,255,0.92)",
        "navbarDark": "rgba(0,0,0,0.75)",
        "heroOverlay": "rgba(0,0,0,0.35)",
        "ctaOverlay": "rgba(0,0,0,0.45)",
        "footerDark": "#1C1C1C"
      },
      "text": {
        "primary": "#111111",
        "secondary": "#555555",
        "muted": "#888888",
        "onDark": "#FFFFFF",
        "onDarkMuted": "rgba(255,255,255,0.65)"
      },
      "accent": {
        "amber": "#E8973A",
        "amberHover": "#C97D28",
        "note": "Used ONLY for highlighted words in section titles and star ratings. NOT used as backgrounds or large fills."
      },
      "stars": "#F5C033",
      "border": "#E8E4DF",
      "stepActiveBg": "#FFFFFF",
      "stepActiveBorder": "#E8E4DF"
    },

    "typography": {
      "fonts": {
        "heading": "Playfair Display, Georgia, serif",
        "body": "DM Sans, sans-serif"
      },
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap",
      "styles": {
        "heroTitle": {
          "fontFamily": "Playfair Display",
          "fontSize": "clamp(36px, 5.5vw, 68px)",
          "fontWeight": 700,
          "lineHeight": 1.1,
          "letterSpacing": "-0.02em",
          "color": "#FFFFFF"
        },
        "sectionTitle": {
          "fontFamily": "Playfair Display",
          "fontSize": "clamp(28px, 3.5vw, 48px)",
          "fontWeight": 700,
          "lineHeight": 1.2,
          "letterSpacing": "-0.02em",
          "color": "#111111"
        },
        "sectionTitleAccent": {
          "color": "#E8973A",
          "note": "Apply to specific words inside sectionTitle only"
        },
        "eyebrow": {
          "fontFamily": "DM Sans",
          "fontSize": "12px",
          "fontWeight": 500,
          "letterSpacing": "0.10em",
          "textTransform": "uppercase",
          "color": "#888888",
          "hasSmallIcon": true,
          "iconDescription": "tiny link/pin SVG icon placed after the text"
        },
        "bodyText": {
          "fontFamily": "DM Sans",
          "fontSize": "14px",
          "fontWeight": 400,
          "lineHeight": 1.7,
          "color": "#555555"
        },
        "navLink": {
          "fontFamily": "DM Sans",
          "fontSize": "14px",
          "fontWeight": 500,
          "color": "#FFFFFF"
        },
        "cardTitle": {
          "fontFamily": "DM Sans",
          "fontSize": "15px",
          "fontWeight": 600,
          "color": "#111111"
        },
        "cardDesc": {
          "fontFamily": "DM Sans",
          "fontSize": "12px",
          "fontWeight": 400,
          "color": "#888888",
          "lineHeight": 1.6
        },
        "price": {
          "fontFamily": "DM Sans",
          "fontSize": "16px",
          "fontWeight": 700,
          "color": "#111111"
        },
        "priceUnit": {
          "fontFamily": "DM Sans",
          "fontSize": "12px",
          "fontWeight": 400,
          "color": "#888888"
        },
        "stepTitle": {
          "fontFamily": "DM Sans",
          "fontSize": "14px",
          "fontWeight": 600,
          "color": "#111111"
        },
        "stepDesc": {
          "fontFamily": "DM Sans",
          "fontSize": "13px",
          "color": "#555555",
          "lineHeight": 1.6
        },
        "testimonialName": {
          "fontFamily": "DM Sans",
          "fontSize": "13px",
          "fontWeight": 600,
          "color": "#111111"
        },
        "testimonialText": {
          "fontFamily": "DM Sans",
          "fontSize": "12px",
          "color": "#555555",
          "lineHeight": 1.6
        },
        "footerColTitle": {
          "fontFamily": "DM Sans",
          "fontSize": "13px",
          "fontWeight": 600,
          "color": "#FFFFFF",
          "marginBottom": "16px"
        },
        "footerLink": {
          "fontFamily": "DM Sans",
          "fontSize": "13px",
          "color": "rgba(255,255,255,0.6)"
        },
        "copyright": {
          "fontFamily": "DM Sans",
          "fontSize": "12px",
          "color": "rgba(255,255,255,0.4)"
        }
      }
